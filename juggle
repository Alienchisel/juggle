#!/usr/bin/env bash

# IVGVLATOR - A personal 3-ball juggling score tracker
#
# Commands:
#   juggle <number>       Log a trial (catches before a drop)
#   juggle scores         Show top 10 high scores
#   juggle scores <N>     Show top N high scores
#   juggle scores all     Show full record, oldest first
#   juggle stats          Show full stats: Title, Apex record, distribution,
#                         chains, trend, and last 20 trials chart
#   juggle last           Show the most recent entry
#   juggle undo           Remove the most recent entry (with confirmation)
#   juggle --help         Show usage help
#
# Data files (default: alongside this script in ./juggle-data/; override with $JUGGLE_DATA_DIR):
#   scores.csv            Every trial: date,time,catches
#   milestones.csv        Omen log (fired omens): type,key
#   pb_history.csv        Apex record: date,time,catches
#   streak_state.csv      Chain peak, last chain, spree count, spree peak, dominance state

SCRIPT_PATH="${BASH_SOURCE[0]}"
if command -v readlink >/dev/null 2>&1; then
    SCRIPT_PATH_RESOLVED="$(readlink -f -- "$SCRIPT_PATH" 2>/dev/null || true)"
    [[ -n "$SCRIPT_PATH_RESOLVED" ]] && SCRIPT_PATH="$SCRIPT_PATH_RESOLVED"
fi
SCRIPT_DIR="$(cd -- "$(dirname -- "$SCRIPT_PATH")" && pwd)"
DATA_DIR="${JUGGLE_DATA_DIR:-$SCRIPT_DIR/juggle-data}"
DATA_FILE="$DATA_DIR/scores.csv"
MILESTONE_FILE="$DATA_DIR/milestones.csv"
PB_FILE="$DATA_DIR/pb_history.csv"
STREAK_FILE="$DATA_DIR/streak_state.csv"  # streak_peak,last_streak,spree_count,spree_peak,dominance_active,dominance_cooldown

# ── Colours ────────────────────────────────────────────────────────────────────
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
MAGENTA='\033[1;35m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

# ── Helpers ────────────────────────────────────────────────────────────────────

init_data() {
    mkdir -p "$DATA_DIR"
    touch "$DATA_FILE"
    touch "$MILESTONE_FILE"
    touch "$PB_FILE"

    # Migrate scores.csv from date,catches → date,time,catches
    local score_fields
    score_fields=$(awk -F',' 'NF{print NF; exit}' "$DATA_FILE")
    if [[ -n "$score_fields" && "$score_fields" != "3" ]]; then
        if (( score_fields == 2 )); then
            local tmp
            tmp=$(mktemp)
            awk -F',' 'BEGIN{OFS=","} NF==2{print $1,"00:00:00",$2; next} {print}' "$DATA_FILE" > "$tmp" && mv "$tmp" "$DATA_FILE"
        fi
    fi

    # Migrate pb_history.csv from date,catches → date,time,catches
    local pb_fields
    pb_fields=$(awk -F',' 'NF{print NF; exit}' "$PB_FILE")
    if [[ -n "$pb_fields" && "$pb_fields" != "3" ]]; then
        if (( pb_fields == 2 )); then
            local tmp
            tmp=$(mktemp)
            awk -F',' 'BEGIN{OFS=","} NF==2{print $1,"00:00:00",$2; next} {print}' "$PB_FILE" > "$tmp" && mv "$tmp" "$PB_FILE"
        fi
    fi

    # streak_state.csv: streak_peak,last_streak,spree_count,spree_peak,dominance_active,dominance_cooldown
    [[ ! -s "$STREAK_FILE" ]] && echo "0,0,0,0,0,0" > "$STREAK_FILE"
    # Migrate older formats if needed
    local fields
    fields=$(awk -F',' 'NR==1{print NF; exit}' "$STREAK_FILE")
    if (( fields < 6 )); then
        local f1 f2 f3 f4
        IFS=',' read -r f1 f2 f3 f4 _ < "$STREAK_FILE"
        echo "${f1:-0},${f2:-0},${f3:-0},${f4:-0},0,0" > "$STREAK_FILE"
    fi
}

all_scores_sorted() {
    sort -t',' -k3,3rn -k1,1r -k2,2r "$DATA_FILE"
}

personal_best() {
    awk -F',' 'NR==1 || $3>max {max=$3} END {print max+0}' "$DATA_FILE"
}

total_sessions() {
    wc -l < "$DATA_FILE" | tr -d ' '
}

milestone_fired() {
    local type=$1 key=$2
    grep -qF "${type},${key}" "$MILESTONE_FILE" 2>/dev/null
}

record_milestone() {
    local type=$1 key=$2
    echo "${type},${key}" >> "$MILESTONE_FILE"
}

print_milestone() {
    echo -e "  ${1}"
}

# ── Apex tracking ──────────────────────────────────────────────────────────────

update_pb_history() {
    local catches=$1
    local today=$2
    local now=$3
    local prev_pb=0
    if [[ -s "$PB_FILE" ]]; then
        prev_pb=$(tail -n1 "$PB_FILE" | cut -d',' -f3)
    fi
    if (( catches > prev_pb )); then
        echo "$today,$now,$catches" >> "$PB_FILE"
    fi
}

# ── Rank system ───────────────────────────────────────────────────────────────

get_rank() {
    local pb=$1
    local title colour

    if   (( pb >= 1000 )); then title="Ball Immortal";   colour="${YELLOW}${BOLD}"
    elif (( pb >= 750  )); then title="Ball Paragon";     colour="${RED}"
    elif (( pb >= 500  )); then title="Ball Legend";      colour="${RED}"
    elif (( pb >= 400  )); then title="Ball Colossus";    colour="${MAGENTA}"
    elif (( pb >= 300  )); then title="Ball Revenant";    colour="${MAGENTA}"
    elif (( pb >= 250  )); then title="Ball Empyrean";    colour="${MAGENTA}"
    elif (( pb >= 200  )); then title="Ball Specter";     colour="${YELLOW}"
    elif (( pb >= 175  )); then title="Ball Auric";       colour="${YELLOW}"
    elif (( pb >= 150  )); then title="Ball Oracle";      colour="${YELLOW}"
    elif (( pb >= 125  )); then title="Ball Luminant";    colour="${YELLOW}"
    elif (( pb >= 100  )); then title="Ball Sovereign";   colour="${GREEN}"
    elif (( pb >= 75   )); then title="Ball Phantom";     colour="${GREEN}"
    elif (( pb >= 50   )); then title="Ball Sage";        colour="${GREEN}"
    elif (( pb >= 40   )); then title="Ball Conjuror";    colour="${CYAN}"
    elif (( pb >= 30   )); then title="Ball Harbinger";   colour="${CYAN}"
    elif (( pb >= 25   )); then title="Ball Knight";      colour="${CYAN}"
    elif (( pb >= 20   )); then title="Ball Keeper";      colour="${CYAN}"
    elif (( pb >= 15   )); then title="Ball Adept";       colour=""
    elif (( pb >= 10   )); then title="Ball Initiate";    colour=""
    elif (( pb >= 5    )); then title="Ball Apprentice";  colour=""
    else                        title="Ball Neophyte";    colour=""
    fi

    echo "${colour}${title}${RESET}"
}

# ── Grade system ───────────────────────────────────────────────────────────────

get_grade() {
    # Returns grade letter and colour given catches and pb
    local catches=$1 pb=$2
    local grade colour
    if (( pb == 0 )); then
        grade="F"; colour="${DIM}"
    else
        local pct=$(( catches * 100 / pb ))
        if   (( pct >= 100 )); then grade="SSS"; colour="${YELLOW}${BOLD}"
        elif (( pct >= 90  )); then grade="SS";  colour="${YELLOW}"
        elif (( pct >= 80  )); then grade="S";   colour="${GREEN}"
        elif (( pct >= 65  )); then grade="A";   colour="${CYAN}"
        elif (( pct >= 50  )); then grade="B";   colour="${CYAN}"
        elif (( pct >= 35  )); then grade="C";   colour="${RED}"
        elif (( pct >= 20  )); then grade="D";   colour="${RED}"
        else                        grade="F";   colour="${DIM}"
        fi
    fi
    echo "${grade}|${colour}"
}

print_grade() {
    local catches=$1 pb=$2
    local grade_info grade colour
    grade_info=$(get_grade "$catches" "$pb")
    grade="${grade_info%%|*}"
    colour="${grade_info##*|}"

    # Block letter definitions — 5 lines each
    local L1 L2 L3 L4 L5
    case "$grade" in
        F)
            L1="█████"; L2="█    "; L3="████ "; L4="█    "; L5="█    "
            ;;
        D)
            L1="████ "; L2="█  █ "; L3="█  █ "; L4="█  █ "; L5="████ "
            ;;
        C)
            L1="█████"; L2="█    "; L3="█    "; L4="█    "; L5="█████"
            ;;
        B)
            L1="████ "; L2="█  █ "; L3="████ "; L4="█  █ "; L5="████ "
            ;;
        A)
            L1=" ███ "; L2="█   █"; L3="█████"; L4="█   █"; L5="█   █"
            ;;
        S)
            L1="█████"; L2="█    "; L3="█████"; L4="    █"; L5="█████"
            ;;
        SS)
            L1="█████ █████"; L2="█     █    "; L3="█████ █████"; L4="    █     █"; L5="█████ █████"
            ;;
        SSS)
            L1="█████ █████ █████"; L2="█     █     █    "; L3="█████ █████ █████"; L4="    █     █     █"; L5="█████ █████ █████"
            ;;
    esac

    echo ""
    echo -e "  ${colour}${L1}${RESET}"
    echo -e "  ${colour}${L2}${RESET}"
    echo -e "  ${colour}${L3}${RESET}"
    echo -e "  ${colour}${L4}${RESET}"
    echo -e "  ${colour}${L5}${RESET}"
    echo ""
}

# ── Log a trial ────────────────────────────────────────────────────────────────

log_score() {
    local catches=$1
    local today
    today=$(date +%Y-%m-%d)
    local now
    now=$(date +%H:%M:%S)
    local pb
    pb=$(personal_best)

    echo "$today,$now,$catches" >> "$DATA_FILE"

    if (( catches > pb )); then
        update_pb_history "$catches" "$today" "$now"
    fi

    echo ""

    if (( catches > pb )); then
        echo -e "  ${YELLOW}${BOLD}★  NEW PERSONAL RECORD!  ★${RESET}"
        echo -e "  ${GREEN}${BOLD}${catches} catches${RESET} — you beat your old best of ${pb}!"
    elif (( catches == pb && pb > 0 )); then
        echo -e "  ${CYAN}${BOLD}Matched your Apex of ${catches}!${RESET} So close to breaking it…"
    elif (( pb > 0 && catches >= pb * 80 / 100 )); then
        echo -e "  ${GREEN}Strong trial!${RESET} ${BOLD}${catches} catches${RESET} — within striking distance of your best (${pb})."
    else
        echo -e "  ${BOLD}${catches} catches${RESET} logged. Keep at it — your best is ${pb}!"
    fi

    # Show current rank (use new pb if record was just broken)
    local display_pb=$(( catches > pb ? catches : pb ))
    local rank_title
    rank_title=$(get_rank "$display_pb")
    echo -e "  ${DIM}Title:${RESET}  ${rank_title}"
    echo ""

    local rank
    rank=$(all_scores_sorted | awk -F',' -v score="$catches" -v date="$today" -v time="$now" '
        { entry_score=$3; entry_date=$1; entry_time=$2 }
        entry_score == score && entry_date == date && entry_time == time && !found { rank=NR; found=1 }
        END { print rank+0 }
    ')

    local total
    total=$(total_sessions)

    if (( rank == 1 )); then
        echo -e "  ${YELLOW}You are #1 on the leaderboard!${RESET}"
    else
        echo -e "  You rank ${BOLD}#${rank}${RESET} out of ${total} trial(s)."
    fi

    echo ""

    check_milestones "$catches" "$total" "$today" "$pb"

    print_grade "$catches" "$display_pb"
    show_scores 10
}

# ── Omens ─────────────────────────────────────────────────────────────────────

check_milestones() {
    local catches=$1
    local total=$2
    local today=$3
    local pb=$4
    local any=0

    # ── Birthday ───────────────────────────────────────────────────────────────
    local month_day
    month_day=$(date +%m-%d)
    local birth_year
    birth_year=$(date +%Y)
    local bkey="birthday_${birth_year}"
    if [[ "$month_day" == "09-15" ]] && ! milestone_fired "birthday" "$bkey"; then
        record_milestone "birthday" "$bkey"
        print_milestone "${YELLOW}${BOLD}🎂 Happy Birthday! Now stop reading this and go juggle some cake.${RESET}"
        any=1
    fi

    # ── Hacker number catches ──────────────────────────────────────────────────
    declare -A hacker_msgs=(
        [13]="Unlucky for some."
        [22]="SSH. You're in."
        [53]="DNS. It's always DNS."
        [69]="Symmetry achieved."
        [80]="Hope you're not running plaintext."
        [404]="Omen not found."
        [443]="Encrypted. Nice."
        [666]="Daemon initialized."
        [1337]="You speak the old tongue."
        [8080]="The other HTTP. Classic dev move."
        [9000]="It's over 9000."
    )
    if [[ -n "${hacker_msgs[$catches]+_}" ]] && ! milestone_fired "hacker" "$catches"; then
        record_milestone "hacker" "$catches"
        print_milestone "${GREEN}// ${hacker_msgs[$catches]}${RESET}"
        any=1
    fi

    # ── 1. Catch-count thresholds ──────────────────────────────────────────────
    local catch_thresholds=(5 10 15 20 25 30 40 50 75 100 150 200)
    local m=250
    while (( catches >= m )); do
        catch_thresholds+=("$m")
        (( m += 50 ))
    done

    local best_catch_threshold=0
    for m in "${catch_thresholds[@]}"; do
        if (( catches >= m )) && ! milestone_fired "catch" "$m"; then
            local count
            count=$(awk -F',' -v v="$m" '$3 >= v' "$DATA_FILE" | wc -l | tr -d ' ')
            if (( count == 1 )); then
                (( m > best_catch_threshold )) && best_catch_threshold=$m
            fi
        fi
    done
    if (( best_catch_threshold > 0 )); then
        for m in "${catch_thresholds[@]}"; do
            if (( m <= best_catch_threshold )) && ! milestone_fired "catch" "$m"; then
                record_milestone "catch" "$m"
            fi
        done
        print_milestone "${YELLOW}🎯 First time reaching ${best_catch_threshold} catches!${RESET}"
        any=1
    fi

    # ── 2. Trial count omens ───────────────────────────────────────────────────
    local session_milestones=(5 10 25 50 75 100 150 200)
    for m in "${session_milestones[@]}"; do
        if (( total == m )) && ! milestone_fired "session" "$m"; then
            record_milestone "session" "$m"
            print_milestone "${CYAN}🎳 ${m} trials logged!${RESET}"
            any=1
        fi
    done
    if (( total > 200 )); then
        local hundreds=$(( (total / 100) * 100 ))
        if (( hundreds > 200 && total == hundreds )) && ! milestone_fired "session" "$hundreds"; then
            record_milestone "session" "$hundreds"
            if (( hundreds % 10000 == 0 )); then
                print_milestone "${MAGENTA}${BOLD}🌟🌟🌟 ${hundreds} TRIALS! A truly legendary juggler. 🌟🌟🌟${RESET}"
            elif (( hundreds % 1000 == 0 )); then
                print_milestone "${YELLOW}${BOLD}🌟🌟 ${hundreds} trials! Extraordinary dedication. 🌟🌟${RESET}"
            else
                print_milestone "${CYAN}🎳 ${hundreds} trials logged!${RESET}"
            fi
            any=1
        fi
    fi

    # ── 3. Monthly average omens ───────────────────────────────────────────────
    local this_month
    this_month=$(date +%Y-%m)
    local month_avg
    month_avg=$(awk -F',' -v m="$this_month" '
        $1 ~ m {s+=$2; n++}
        END {if(n>0) printf "%.1f", s/n; else print "0"}
    ' "$DATA_FILE")

    local best_avg_threshold=0
    local threshold=5
    while awk "BEGIN {exit !($month_avg >= $threshold)}"; do
        local mkey="${this_month}_avg_${threshold}"
        if ! milestone_fired "monthavg" "$mkey"; then
            best_avg_threshold=$threshold
        fi
        (( threshold += 5 ))
    done
    if (( best_avg_threshold > 0 )); then
        threshold=5
        while (( threshold <= best_avg_threshold )); do
            local mkey="${this_month}_avg_${threshold}"
            ! milestone_fired "monthavg" "$mkey" && record_milestone "monthavg" "$mkey"
            (( threshold += 5 ))
        done
        print_milestone "${GREEN}📅 This month's average has crossed ${best_avg_threshold} catches!${RESET}"
        any=1
    fi

    # ── 4. Comeback ────────────────────────────────────────────────────────────
    if (( total > 1 )); then
        local prev_date
        prev_date=$(tail -n2 "$DATA_FILE" | head -n1 | cut -d',' -f1)
        local days_since
        days_since=$(( ( $(date -d "$today" +%s) - $(date -d "$prev_date" +%s) ) / 86400 ))
        if (( days_since >= 7 )); then
            print_milestone "${GREEN}👋 Welcome back! It's been ${days_since} days since your last trial.${RESET}"
            any=1
        fi
    fi

    # ── 5. Apex anniversary ───────────────────────────────────────────────────
    local pb_date pb_session_num
    read -r pb_date pb_session_num <<< "$(awk -F',' -v pb="$pb" '
        $2 == pb && !found { print $1, NR; found=1 }
    ' "$DATA_FILE")"

    if [[ -n "$pb_date" ]]; then
        local days_since_pb
        days_since_pb=$(( ( $(date -d "$today" +%s) - $(date -d "$pb_date" +%s) ) / 86400 ))
        local sessions_since_pb=$(( total - pb_session_num ))

        local day_thresholds=(7 14 30)
        local dt=60
        while (( days_since_pb >= dt )); do
            day_thresholds+=("$dt")
            (( dt += 30 ))
        done
        local best_day_threshold=0
        for dt in "${day_thresholds[@]}"; do
            if (( days_since_pb >= dt )); then
                local dkey="pb_days_${pb}_${dt}"
                ! milestone_fired "pbanniv" "$dkey" && best_day_threshold=$dt
            fi
        done
        if (( best_day_threshold > 0 )); then
            for dt in "${day_thresholds[@]}"; do
                if (( dt <= best_day_threshold )); then
                    local dkey="pb_days_${pb}_${dt}"
                    ! milestone_fired "pbanniv" "$dkey" && record_milestone "pbanniv" "$dkey"
                fi
            done
            print_milestone "${MAGENTA}📌 Your Apex of ${pb} catches is ${best_day_threshold}+ days old — time to break it!${RESET}"
            any=1
        fi

        local sess_thresholds=(10 25)
        local st=50
        while (( sessions_since_pb >= st )); do
            sess_thresholds+=("$st")
            (( st += 25 ))
        done
        local best_sess_threshold=0
        for st in "${sess_thresholds[@]}"; do
            if (( sessions_since_pb >= st )); then
                local skey="pb_sess_${pb}_${st}"
                ! milestone_fired "pbanniv" "$skey" && best_sess_threshold=$st
            fi
        done
        if (( best_sess_threshold > 0 )); then
            for st in "${sess_thresholds[@]}"; do
                if (( st <= best_sess_threshold )); then
                    local skey="pb_sess_${pb}_${st}"
                    ! milestone_fired "pbanniv" "$skey" && record_milestone "pbanniv" "$skey"
                fi
            done
            print_milestone "${MAGENTA}📌 ${best_sess_threshold} trials since your last Apex of ${pb} — it's waiting to be broken!${RESET}"
            any=1
        fi
    fi

    # ── 7. Chain omens ─────────────────────────────────────────────────────────
    # Read streak state: streak_peak,last_streak,spree_count,spree_peak,dominance_active,dominance_cooldown
    local streak_peak streak_last spree_count spree_peak dominance_active dominance_cooldown
    IFS=',' read -r streak_peak streak_last spree_count spree_peak dominance_active dominance_cooldown < "$STREAK_FILE"
    streak_peak=${streak_peak:-0}
    streak_last=${streak_last:-0}
    spree_count=${spree_count:-0}
    spree_peak=${spree_peak:-0}
    dominance_active=${dominance_active:-0}
    dominance_cooldown=${dominance_cooldown:-0}

    # Calculate current streak length
    local cur_streak best_streak
    read -r cur_streak best_streak <<< "$(calc_streaks)"

    # Check if chain was broken since last trial
    if (( streak_peak >= 3 && cur_streak == 1 && total > 1 )); then
        print_milestone "${DIM}Chain of ${streak_last} days ended.${RESET}"
        any=1
        streak_peak=0
    fi

    # Build list of streak thresholds
    local streak_thresholds=(3 7 14 30 60 90 180 365)
    local t=730
    while (( cur_streak >= t )); do
        streak_thresholds+=("$t")
        (( t += 365 ))
    done

    # Find highest unfired streak threshold
    local best_streak_threshold=0
    for t in "${streak_thresholds[@]}"; do
        if (( cur_streak >= t && t > streak_peak )); then
            best_streak_threshold=$t
        fi
    done

    if (( best_streak_threshold > 0 )); then
        local smsg
        if (( best_streak_threshold % 365 == 0 && best_streak_threshold >= 365 )); then
            local years=$(( best_streak_threshold / 365 ))
            if (( years == 1 )); then
                smsg="${best_streak_threshold} days in a row. A full year."
            else
                smsg="${best_streak_threshold} days in a row. ${years} years."
            fi
        else
            smsg="${best_streak_threshold} days in a row."
        fi
        print_milestone "${GREEN}⛓  ${smsg}${RESET}"
        any=1
        streak_peak=$best_streak_threshold
    fi

    # ── 8. Spree omens ─────────────────────────────────────────────────────────
    # Determine if this trial is B or above (>= 50% of pb)
    local display_pb_for_spree=$(( catches > pb ? catches : pb ))
    local is_good_session=0
    if (( display_pb_for_spree > 0 )); then
        local pct=$(( catches * 100 / display_pb_for_spree ))
        (( pct >= 50 )) && is_good_session=1
    fi

    if (( is_good_session )); then
        (( spree_count++ ))

        # Build spree thresholds: 3,5,7,10,15 then every 5
        local spree_thresholds=(3 5 7 10 15)
        local s=20
        while (( spree_count >= s )); do
            spree_thresholds+=("$s")
            (( s += 5 ))
        done

        # Find highest unfired spree threshold
        local best_spree_threshold=0
        for s in "${spree_thresholds[@]}"; do
            if (( spree_count >= s && s > spree_peak )); then
                best_spree_threshold=$s
            fi
        done

        if (( best_spree_threshold > 0 )); then
            local spree_msg
            if   (( best_spree_threshold >= 15 )); then spree_msg="Godlike!"
            elif (( best_spree_threshold >= 10 )); then spree_msg="Unstoppable!"
            elif (( best_spree_threshold >=  7 )); then spree_msg="Dominating!"
            elif (( best_spree_threshold >=  5 )); then spree_msg="Rampage!"
            else                                        spree_msg="Balling Spree!"
            fi
            print_milestone "${CYAN}🎯 ${spree_msg}${RESET}"
            any=1
            spree_peak=$best_spree_threshold
        fi
    else
        # Bad trial — check if spree is ending
        if (( spree_peak >= 3 )); then
            print_milestone "${DIM}Spree of ${spree_count} trials ended.${RESET}"
            any=1
        fi
        spree_count=0
        spree_peak=0
    fi

    # ── 9. Dominance omen ──────────────────────────────────────────────────────
    # Fires when >= 5 of last 10 trials are S+ (>= 80% of current pb)
    local effective_pb=$(( catches > pb ? catches : pb ))
    local dom_now=0
    if (( effective_pb > 0 && total >= 10 )); then
        local s_count
        s_count=$(tail -n10 "$DATA_FILE" | awk -F',' -v pb="$effective_pb" '
            { pct = ($3 * 100) / pb; if (pct >= 80) count++ }
            END { print count+0 }
        ')
        (( s_count >= 5 )) && dom_now=1
    fi

    # Tick down cooldown
    (( dominance_cooldown > 0 )) && (( dominance_cooldown-- ))

    if (( dom_now )); then
        if (( dominance_active == 0 || dominance_cooldown == 0 )); then
            print_milestone "${YELLOW}👁  Dominating!${RESET}"
            any=1
            dominance_active=1
            dominance_cooldown=10
        fi
    else
        if (( dominance_active == 1 )); then
            print_milestone "${DIM}Dominance faded.${RESET}"
            any=1
            dominance_active=0
            dominance_cooldown=0
        fi
    fi

    # Save updated state
    echo "${streak_peak},${cur_streak},${spree_count},${spree_peak},${dominance_active},${dominance_cooldown}" > "$STREAK_FILE"

    # ── 6. Rank advancement ────────────────────────────────────────────────────
    # Fires when a new Apex crosses into a new rank tier
    if (( catches > pb )); then
        local new_rank old_rank
        new_rank=$(get_rank "$catches")
        old_rank=$(get_rank "$pb")
        # Strip colour codes for comparison
        local new_rank_plain old_rank_plain
        new_rank_plain=$(echo -e "$new_rank" | sed 's/\x1b\[[0-9;]*m//g')
        old_rank_plain=$(echo -e "$old_rank" | sed 's/\x1b\[[0-9;]*m//g')
        if [[ "$new_rank_plain" != "$old_rank_plain" ]]; then
            print_milestone "⚔️  Title claimed: ${new_rank}"
            any=1
        fi
    fi

    if (( any )); then
        echo ""
    fi
}

