# ── Main ───────────────────────────────────────────────────────────────────────

init_data

case "$1" in
    ''|--help|-h)
        usage
        ;;
    top)
        if [[ -z "$2" ]]; then
            show_scores 10 | gum_pager
        elif [[ "$2" == "all" ]]; then
            show_scores all | gum_pager
        elif [[ "$2" =~ ^[0-9]+$ ]]; then
            show_scores "$2" | gum_pager
        else
            echo -e "\n  ${RED}Unknown argument:${RESET} juggle top ${2}\n"
            usage
        fi
        ;;
    stats)
        show_stats | gum_pager
        ;;
    pb)
        show_apex | gum_pager
        ;;
    trend)
        show_trend | gum_pager
        ;;
    day)
        show_day "$2" | gum_pager
        ;;
    week)
        show_week "$2" | gum_pager
        ;;
    month)
        show_month "$2" | gum_pager
        ;;
    year)
        show_year "$2" | gum_pager
        ;;
    last)
        if [[ -z "$2" ]]; then
            show_last 1 | gum_pager
        elif [[ "$2" =~ ^[0-9]+$ ]]; then
            show_last "$2" | gum_pager
        else
            echo -e "\n  ${RED}Unknown argument:${RESET} juggle last ${2}\n"
            usage
        fi
        ;;
    undo)
        undo_last
        ;;
    lore)
        show_lore | gum_pager
        ;;
    codex)
        show_codex | gum_pager
        ;;
    *)
        if [[ "$1" =~ ^[0-9]+$ ]] && (( $1 >= 1 )); then
            log_score "$1"
        else
            echo -e "\n  ${RED}Not a valid catch count:${RESET} '$1'\n"
            usage
        fi
        ;;
esac
