# ── Main ───────────────────────────────────────────────────────────────────────

init_data

case "$1" in
    ''|--help|-h)
        usage
        ;;
    scores)
        if [[ -z "$2" ]]; then
            show_scores 10
        elif [[ "$2" == "all" ]]; then
            show_scores all
        elif [[ "$2" =~ ^[0-9]+$ ]]; then
            show_scores "$2"
        else
            echo -e "\n  ${RED}Unknown argument:${RESET} juggle scores ${2}\n"
            usage
        fi
        ;;
    stats)
        show_stats
        ;;
    last)
        show_last
        ;;
    undo)
        undo_last
        ;;
    balls)
        juggle_balls
        ;;
    *)
        if [[ "$1" =~ ^[0-9]+$ ]]; then
            log_score "$1"
        else
            echo -e "\n  ${RED}Not a valid catch count:${RESET} '$1'\n"
            usage
        fi
        ;;
esac
