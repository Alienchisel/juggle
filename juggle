# ── Show Annals ────────────────────────────────────────────────────────────────

show_scores() {
    local limit=$1
    if [[ -z "$limit" ]]; then
        limit=10
    fi

    local total
    total=$(total_sessions)

    local pb
    pb=$(personal_best)

    # Sets _g (grade letter) and _gc (grade colour) without a subshell
    _grd() {
        local _c=$1 _pct=0
        (( pb > 0 )) && _pct=$(( _c * 100 / pb ))
        if   (( _pct >= 100 )); then _g="SSS"; _gc="${YELLOW}${BOLD}"
        elif (( _pct >= 90  )); then _g="SS";  _gc="${YELLOW}"
        elif (( _pct >= 80  )); then _g="S";   _gc="${GREEN}"
        elif (( _pct >= 65  )); then _g="A";   _gc="${CYAN}"
        elif (( _pct >= 50  )); then _g="B";   _gc="${CYAN}"
        elif (( _pct >= 35  )); then _g="C";   _gc="${RED}"
        elif (( _pct >= 20  )); then _g="D";   _gc="${RED}"
        else                         _g="F";   _gc="${DIM}"
        fi
    }

    gum_header "TRIUMPHS"

    if (( total == 0 )); then
        echo -e "  ${DIM}No trials yet. Run ${RESET}${BOLD}juggle <catches>${RESET}${DIM} to get started!${RESET}"
        echo -e "  ${DIM}──────────────────────────────────────${RESET}"
        echo ""
        return
    fi

    if [[ "$limit" == "all" ]]; then
        echo -e "  ${DIM}Full record — oldest first${RESET}"
        echo -e "  ${DIM}──────────────────────────────────────${RESET}"
        local i=1
        while IFS=',' read -r date time catches; do
            _grd "$catches"
            printf "  ${DIM}%4d.${RESET}  ${BOLD}%3d catches${RESET}   ${DIM}%s${RESET}   ${_gc}%-3s${RESET}\n" \
                "$i" "$catches" "$date" "$_g"
            (( i++ ))
        done < "$DATA_FILE"
    else
        local i=1
        while IFS=',' read -r date time catches; do
            _grd "$catches"
            if (( i == 1 )); then
                printf "  ${YELLOW}${BOLD}%3d.  %3d catches   %s${RESET}   ${_gc}${BOLD}%-3s${RESET}\n" \
                    "$i" "$catches" "$date" "$_g"
            elif (( i <= 3 )); then
                printf "  ${CYAN}${BOLD}%3d.  %3d catches   %s${RESET}   ${_gc}${BOLD}%-3s${RESET}\n" \
                    "$i" "$catches" "$date" "$_g"
            else
                printf "  ${BOLD}%3d.${RESET}  ${BOLD}%3d catches${RESET}   ${DIM}%s${RESET}   ${_gc}%-3s${RESET}\n" \
                    "$i" "$catches" "$date" "$_g"
            fi
            (( i++ ))
            if [[ "$limit" != "all" ]] && (( i > limit )); then
                break
            fi
        done < <(all_scores_sorted)
    fi

    echo -e "  ${DIM}──────────────────────────────────────${RESET}"
    echo -e "  ${DIM}${total} total trial(s) on record${RESET}"
    echo ""
}

# ── Streak calculation ─────────────────────────────────────────────────────────

calc_streaks() {
    # Pure awk — YYYY-MM-DD dates compare correctly as strings.
    # We convert each date to a day-number (days since an arbitrary epoch)
    # using Zeller-style arithmetic entirely inside awk, no shell date calls.
    awk -F',' '
    function date_to_days(d,    y,m,dy) {
        y  = substr(d,1,4)+0
        m  = substr(d,6,2)+0
        dy = substr(d,9,2)+0
        # Adjust for Jan/Feb
        if (m <= 2) { m += 12; y-- }
        return int(365.25*(y+4716)) + int(30.6001*(m+1)) + dy - 1524
    }
    {
        dates[NR] = $1
    }
    END {
        if (NR == 0) { print 0, 0; exit }

    # Deduplicate dates (multiple trials same day count as one chain day)
        n = 0
        prev = ""
        for (i = 1; i <= NR; i++) {
            if (dates[i] != prev) {
                n++
                ud[n] = dates[i]
                prev = dates[i]
            }
        }

        # Current streak — walk backwards from last unique date
        cur = 1
        for (i = n; i > 1; i--) {
            if (date_to_days(ud[i]) - date_to_days(ud[i-1]) == 1) cur++
            else break
        }

        # Best streak — full scan
        best = 1; run = 1
        for (i = 2; i <= n; i++) {
            if (date_to_days(ud[i]) - date_to_days(ud[i-1]) == 1) {
                run++
                if (run > best) best = run
            } else {
                run = 1
            }
        }
        if (cur > best) best = cur
        print cur, best
    }' "$DATA_FILE"
}

# ── Trend ──────────────────────────────────────────────────────────────────────

show_trend() {
    local total
    total=$(total_sessions)
    if (( total == 0 )); then
        echo -e "\n  No trials logged yet.\n"
        return
    fi

    gum_header "THE TREND"

    local today dow week_start
    today=$(date +%Y-%m-%d)
    dow=$(date +%u)
    week_start=$(date -d "$today -$(( dow - 1 )) days" +%Y-%m-%d)

    # ── Week-over-week ─────────────────────────────────────────────────────────
    local last_week_start last_week_end
    last_week_start=$(date -d "$week_start -7 days" +%Y-%m-%d)
    last_week_end=$(date -d "$week_start -1 day" +%Y-%m-%d)

    local this_week_avg last_week_avg
    this_week_avg=$(awk -F',' -v ws="$week_start" '
        $1 >= ws { s+=$3; n++ }
        END { printf "%.1f", (n>0 ? s/n : 0) }
    ' "$DATA_FILE")
    last_week_avg=$(awk -F',' -v s="$last_week_start" -v e="$last_week_end" '
        $1 >= s && $1 <= e { sum+=$3; n++ }
        END { printf "%.1f", (n>0 ? sum/n : 0) }
    ' "$DATA_FILE")

    local week_diff week_sign
    week_diff=$(awk "BEGIN {printf \"%.1f\", $this_week_avg - $last_week_avg}")
    if awk "BEGIN {exit !($week_diff > 0)}"; then
        week_sign="${GREEN}▲ +${week_diff}${RESET}"
    elif awk "BEGIN {exit !($week_diff < 0)}"; then
        week_sign="${RED}▼ ${week_diff}${RESET}"
    else
        week_sign="${DIM}= no change${RESET}"
    fi

    # ── Month-over-month ───────────────────────────────────────────────────────
    local this_month last_month
    this_month=$(date +%Y-%m)
    last_month=$(date -d "$today -1 month" +%Y-%m)

    local this_month_avg last_month_avg
    this_month_avg=$(awk -F',' -v m="$this_month" '
        $1 ~ m { s+=$3; n++ }
        END { printf "%.1f", (n>0 ? s/n : 0) }
    ' "$DATA_FILE")
    last_month_avg=$(awk -F',' -v m="$last_month" '
        $1 ~ m { s+=$3; n++ }
        END { printf "%.1f", (n>0 ? s/n : 0) }
    ' "$DATA_FILE")

    local month_diff month_sign
    month_diff=$(awk "BEGIN {printf \"%.1f\", $this_month_avg - $last_month_avg}")
    if awk "BEGIN {exit !($month_diff > 0)}"; then
        month_sign="${GREEN}▲ +${month_diff}${RESET}"
    elif awk "BEGIN {exit !($month_diff < 0)}"; then
        month_sign="${RED}▼ ${month_diff}${RESET}"
    else
        month_sign="${DIM}= no change${RESET}"
    fi

    # ── Recent trend (last 5 vs prev 5) ───────────────────────────────────────
    local trend_line=""
    if (( total >= 10 )); then
        local prev5_avg last5_avg
        read -r prev5_avg last5_avg <<< "$(tail -n10 "$DATA_FILE" | awk -F',' '
            NR<=5 { s1+=$3; n1++ }
            NR>5  { s2+=$3; n2++ }
            END   { printf "%.1f %.1f", (n1>0?s1/n1:0), (n2>0?s2/n2:0) }
        ')"
        local diff
        diff=$(awk "BEGIN {printf \"%.1f\", $last5_avg - $prev5_avg}")
        local sign
        if awk "BEGIN {exit !($diff > 0)}"; then
            sign="${GREEN}▲ +${diff}${RESET}"
        elif awk "BEGIN {exit !($diff < 0)}"; then
            sign="${RED}▼ ${diff}${RESET}"
        else
            sign="${DIM}= no change${RESET}"
        fi
        trend_line="  ${BOLD}Last 10 trials :${RESET}  prev 5 avg ${prev5_avg}  →  last 5 avg ${last5_avg}  ${sign}"
    fi

    # ── Weekly sparkline (last 12 weeks) ──────────────────────────────────────
    local sparks=()
    local spark_avgs=()
    local spark_min=999999 spark_max=0
    for (( w=11; w>=0; w-- )); do
        local ws we
        ws=$(date -d "$week_start -$(( w * 7 )) days" +%Y-%m-%d)
        we=$(date -d "$ws +6 days" +%Y-%m-%d)
        local wavg
        wavg=$(awk -F',' -v s="$ws" -v e="$we" '
            $1 >= s && $1 <= e { sum+=$3; n++ }
            END { printf "%.1f", (n>0 ? sum/n : 0) }
        ' "$DATA_FILE")
        spark_avgs+=("$wavg")
        local wi
        wi=$(awk "BEGIN {printf \"%d\", int($wavg)}")
        if (( wi > 0 )); then
            (( wi < spark_min )) && spark_min=$wi
            (( wi > spark_max )) && spark_max=$wi
        fi
    done

    local spark_chars=("▁" "▂" "▃" "▄" "▅" "▆" "▇" "█")
    local sparkline=""
    local has_data=0
    for wavg in "${spark_avgs[@]}"; do
        local wi
        wi=$(awk "BEGIN {printf \"%d\", int($wavg)}")
        if (( wi == 0 )); then
            sparkline+="${DIM}·${RESET}"
        else
            has_data=1
            local range=$(( spark_max - spark_min ))
            local idx
            if (( range == 0 )); then
                idx=3
            else
                idx=$(( (wi - spark_min) * 7 / range ))
            fi
            sparkline+="${spark_chars[$idx]}"
        fi
    done

    # ── Time-of-day breakdown (last 12 weeks) ────────────────────────────────
    # Skip entries with placeholder timestamp 00:00:00 (migrated from timeless records)
    local tod_window_start
    tod_window_start=$(date -d "$week_start -11 weeks" +%Y-%m-%d)
    local tod_data tod_real_count
    tod_real_count=$(awk -F',' -v from="$tod_window_start" '$1 >= from && $2 != "00:00:00"' "$DATA_FILE" | wc -l | tr -d ' ')
    tod_data=$(awk -F',' -v from="$tod_window_start" '
        $1 < from { next }
        $2 == "00:00:00" { next }
        {
            split($2, t, ":"); h = t[1]+0
            if      (h <= 5)  vigil++
            else if (h <= 11) dawn++
            else if (h <= 17) meridian++
            else              dusk++
            hour[h]++
        }
        END {
            printf "%d %d %d %d", vigil+0, dawn+0, meridian+0, dusk+0
            for (i=0; i<24; i++) printf " %d", hour[i]+0
        }
    ' "$DATA_FILE")

    local tod_vigil tod_dawn tod_meridian tod_dusk
    read -r tod_vigil tod_dawn tod_meridian tod_dusk \
        h0  h1  h2  h3  h4  h5  h6  h7  h8  h9  h10 h11 \
        h12 h13 h14 h15 h16 h17 h18 h19 h20 h21 h22 h23 <<< "$tod_data"

    local tod_max=0
    for band in "$tod_vigil" "$tod_dawn" "$tod_meridian" "$tod_dusk"; do
        (( band > tod_max )) && tod_max=$band
    done

    # Build a bar of width 10 for each band
    tod_bar() {
        local count=$1 max=$2 width=10
        local filled=0
        (( max > 0 )) && filled=$(( count * width / max ))
        local bar=""
        for (( b=0; b<width; b++ )); do
            if (( b < filled )); then bar+="█"; else bar+="░"; fi
        done
        local pct=0
        (( tod_real_count > 0 )) && pct=$(( count * 100 / tod_real_count ))
        printf "%s  %3d%%" "$bar" "$pct"
    }

    # Build 24-char hourly sparkline
    local hour_vals=( "$h0"  "$h1"  "$h2"  "$h3"  "$h4"  "$h5"
                      "$h6"  "$h7"  "$h8"  "$h9"  "$h10" "$h11"
                      "$h12" "$h13" "$h14" "$h15" "$h16" "$h17"
                      "$h18" "$h19" "$h20" "$h21" "$h22" "$h23" )
    local hour_max=0
    for hv in "${hour_vals[@]}"; do (( hv > hour_max )) && hour_max=$hv; done

    local spark_chars=("▁" "▂" "▃" "▄" "▅" "▆" "▇" "█")
    local hour_spark=""
    for hv in "${hour_vals[@]}"; do
        if (( hv == 0 )); then
            hour_spark+="${DIM}·${RESET}"
        else
            local idx=0
            (( hour_max > 0 )) && idx=$(( hv * 7 / hour_max ))
            hour_spark+="${spark_chars[$idx]}"
        fi
    done

    # ── Day-of-week breakdown (last 12 weeks) ────────────────────────────────
    local dow_window_start
    dow_window_start=$(date -d "$week_start -11 weeks" +%Y-%m-%d)
    local dow_data
    dow_data=$(awk -F',' -v from="$dow_window_start" '
        $1 < from { next }
        {
            split($1, dt, "-")
            t = mktime(dt[1] " " dt[2] " " dt[3] " 12 0 0")
            dow = strftime("%u", t) + 0
            sum[dow] += $3
            count[dow]++
        }
        END {
            for (d = 1; d <= 7; d++)
                printf "%d %d ", sum[d]+0, count[d]+0
        }
    ' "$DATA_FILE")

    local dow_avgs=() dow_counts=()
    read -r -a _dow_vals <<< "$dow_data"
    local dow_max_avg=0
    for (( _d=0; _d<7; _d++ )); do
        local _ds=${_dow_vals[$(( _d*2 ))]} _dc=${_dow_vals[$(( _d*2+1 ))]}
        dow_counts+=("$_dc")
        local _da=0
        (( _dc > 0 )) && _da=$(awk "BEGIN {printf \"%.1f\", $_ds/$_dc}")
        dow_avgs+=("$_da")
        local _dai
        _dai=$(awk "BEGIN {printf \"%d\", int($_da)}")
        (( _dai > dow_max_avg )) && dow_max_avg=$_dai
    done

    # ── Output ─────────────────────────────────────────────────────────────────
    echo ""
    echo -e "  ${DIM}──────────────────────────────────────${RESET}"
    echo -e "  ${BOLD}TREND${RESET}"
    echo -e "  ${DIM}──────────────────────────────────────${RESET}"
    echo -e "  ${BOLD}This week      :${RESET}  avg ${this_week_avg}  ${DIM}(last week: ${last_week_avg})${RESET}  ${week_sign}"
    echo -e "  ${BOLD}This month     :${RESET}  avg ${this_month_avg}  ${DIM}(last month: ${last_month_avg})${RESET}  ${month_sign}"
    if [[ -n "$trend_line" ]]; then
        echo -e "$trend_line"
    fi
    if (( has_data )); then
        echo ""
        echo -e "  ${BOLD}Weekly avg${RESET}  ${DIM}(12 weeks)${RESET}"
        echo -e "  ${sparkline}"
        echo -e "  ${DIM}└ oldest                newest ┘${RESET}"
    fi

    echo ""
    echo -e "  ${DIM}──────────────────────────────────────${RESET}"
    echo -e "  ${BOLD}DAY OF WEEK${RESET}  ${DIM}(last 12 weeks)${RESET}"
    echo -e "  ${DIM}──────────────────────────────────────${RESET}"
    local _dow_names=("Mon" "Tue" "Wed" "Thu" "Fri" "Sat" "Sun")
    for (( _d=0; _d<7; _d++ )); do
        local _da=${dow_avgs[$_d]} _dc=${dow_counts[$_d]}
        local _bar="" _dai _filled=0
        _dai=$(awk "BEGIN {printf \"%d\", int($_da)}")
        (( dow_max_avg > 0 )) && _filled=$(( _dai * 10 / dow_max_avg ))
        for (( _b=0; _b<10; _b++ )); do
            if (( _b < _filled )); then _bar+="█"; else _bar+="░"; fi
        done
        if (( _dc == 0 )); then
            printf "  ${BOLD}%-4s${RESET}  ${DIM}░░░░░░░░░░  no data${RESET}\n" "${_dow_names[$_d]}"
        else
            printf "  ${BOLD}%-4s${RESET}  %s  %4.1f avg  ${DIM}(%d)${RESET}\n" \
                "${_dow_names[$_d]}" "$_bar" "$_da" "$_dc"
        fi
    done

    echo ""
    echo -e "  ${DIM}──────────────────────────────────────${RESET}"
    echo -e "  ${BOLD}WHEN YOU TRAIN${RESET}  ${DIM}(last 12 weeks)${RESET}"
    echo -e "  ${DIM}──────────────────────────────────────${RESET}"
    if (( tod_real_count == 0 )); then
        echo -e "  ${DIM}No timestamped entries yet.${RESET}"
    else
        printf "  ${BOLD}%-10s${RESET}  %s\n" "Dawn"     "$(tod_bar "$tod_dawn"     "$tod_max")"
        printf "  ${BOLD}%-10s${RESET}  %s\n" "Meridian" "$(tod_bar "$tod_meridian" "$tod_max")"
        printf "  ${BOLD}%-10s${RESET}  %s\n" "Dusk"     "$(tod_bar "$tod_dusk"     "$tod_max")"
        printf "  ${BOLD}%-10s${RESET}  %s\n" "Vigil"    "$(tod_bar "$tod_vigil"    "$tod_max")"
        echo ""
        echo -e "  ${BOLD}By hour${RESET}    ${hour_spark}"
        echo -e "  ${DIM}           └ 00                  23 ┘${RESET}"
    fi
    echo ""
}

# ── Apex Record ────────────────────────────────────────────────────────────────

show_apex() {
    local pb=${1:-$(personal_best)}
    local no_header=${2:-}

    if [[ ! -s "$PB_FILE" ]]; then
        echo -e "\n  No Apex set yet.\n"
        return
    fi

    local pb_count
    pb_count=$(wc -l < "$PB_FILE" | tr -d ' ')
    local skip=$(( pb_count > 10 ? pb_count - 10 : 0 ))
    local prev_val=0
    local i=0

    [[ -z "$no_header" ]] && gum_header "APEX RECORD"
    while IFS=',' read -r ph_date ph_time ph_val; do
        (( i++ ))
        (( i <= skip )) && prev_val=$ph_val && continue
        local diff_str=""
        if (( prev_val == 0 )); then
            diff_str="${DIM}start${RESET}"
        else
            local d=$(( ph_val - prev_val ))
            diff_str="${GREEN}+${d}${RESET}"
        fi
        local grade_info grade grade_colour
        grade_info=$(get_grade "$ph_val" "$pb")
        grade="${grade_info%%|*}"
        grade_colour="${grade_info##*|}"
        if (( ph_val == pb )); then
            printf "  ${YELLOW}${BOLD}%-12s %8s  %3d catches${RESET}  %b  ${grade_colour}${BOLD}%-3s${RESET}  ${DIM}← current${RESET}  ${BLOOD}${BOLD}Sine pari.${RESET}\n" \
                "$ph_date" "$ph_time" "$ph_val" "$diff_str" "$grade"
        else
            printf "  ${DIM}%-12s %8s${RESET}  ${BOLD}%3d catches${RESET}  %b  ${grade_colour}%-3s${RESET}\n" \
                "$ph_date" "$ph_time" "$ph_val" "$diff_str" "$grade"
        fi
        prev_val=$ph_val
    done < "$PB_FILE"
    echo ""
}

# ── Stats ──────────────────────────────────────────────────────────────────────

show_stats() {
    local total
    total=$(total_sessions)

    if (( total == 0 )); then
        echo -e "\n  No trials logged yet. Run ${BOLD}juggle <catches>${RESET} to start!\n"
        return
    fi

    local pb
    pb=$(personal_best)

    local avg sum
    read -r sum avg <<< "$(awk -F',' '{s+=$3} END {printf "%d %.1f", s, s/NR}' "$DATA_FILE")"

    local median
    median=$(awk -F',' '{print $3+0}' "$DATA_FILE" | sort -n | awk '
        { vals[NR] = $1 }
        END {
            n = NR
            if (n % 2 == 1) printf "%.1f", vals[(n+1)/2]
            else             printf "%.1f", (vals[n/2] + vals[n/2+1]) / 2
        }')

    local last_date last_time last_catches
    IFS=',' read -r last_date last_time last_catches <<< "$(tail -n1 "$DATA_FILE")"

    # Days since Apex
    local pb_date
    pb_date=$(awk -F',' -v pb="$pb" '$3==pb && !found {print $1; found=1}' "$DATA_FILE")
    local today
    today=$(date +%Y-%m-%d)
    local days_since_pb=0
    if [[ -n "$pb_date" ]]; then
        days_since_pb=$(( ( $(date -d "$today" +%s) - $(date -d "$pb_date" +%s) ) / 86400 ))
    fi

    # This month
    local this_month
    this_month=$(date +%Y-%m)
    local month_sessions month_avg
    read -r month_sessions month_avg <<< "$(awk -F',' -v m="$this_month" '
        $1 ~ m {s+=$3; n++}
        END {printf "%d %.1f", n+0, (n>0 ? s/n : 0)}
    ' "$DATA_FILE")"

    # Best month by average
    local best_month best_month_avg
    read -r best_month best_month_avg <<< "$(awk -F',' '
        {
            split($1, d, "-")
            key = d[1] "-" d[2]
            sum[key] += $3
            count[key]++
        }
        END {
            best_avg = 0; best_key = ""
            for (k in sum) {
                a = sum[k] / count[k]
                if (a > best_avg) { best_avg = a; best_key = k }
            }
            printf "%s %.1f", best_key, best_avg
        }
    ' "$DATA_FILE")"

    # ── Trials per week ───────────────────────────────────────────────────────
    # Based on actual date span; floored to 1 day minimum
    local first_date
    first_date=$(head -n1 "$DATA_FILE" | cut -d',' -f1)
    local total_days=1
    if [[ -n "$first_date" && "$first_date" != "$today" ]]; then
        total_days=$(( ( $(date -d "$today" +%s) - $(date -d "$first_date" +%s) ) / 86400 ))
        (( total_days < 1 )) && total_days=1
    fi
    local sessions_per_week
    sessions_per_week=$(awk "BEGIN {printf \"%.1f\", $total * 7 / $total_days}")

    # This week (Monday–today)
    local week_start
    local dow
    dow=$(date +%u)  # 1=Mon, 7=Sun
    week_start=$(date -d "$today -$(( dow - 1 )) days" +%Y-%m-%d)
    local this_week_sessions
    this_week_sessions=$(awk -F',' -v ws="$week_start" '$1 >= ws' "$DATA_FILE" | wc -l | tr -d ' ')

    local best_this_week best_this_month
    best_this_week=$(awk -F',' -v ws="$week_start" '$1 >= ws {if ($3+0 > best) best=$3+0} END {print best+0}' "$DATA_FILE")
    best_this_month=$(awk -F',' -v m="$this_month" '$1 ~ m {if ($3+0 > best) best=$3+0} END {print best+0}' "$DATA_FILE")

    # Streaks
    local cur_streak best_streak
    read -r cur_streak best_streak <<< "$(calc_streaks)"

    # Floor (10th-percentile) and Ceiling (90th-percentile) of last 20 trials
    local floor_val ceiling_val
    read -r floor_val ceiling_val <<< "$(tail -n20 "$DATA_FILE" | awk -F',' '
        {vals[NR]=$3}
        END {
            n=NR
            for(i=1;i<=n;i++) for(j=i+1;j<=n;j++) if(vals[j]<vals[i]) {t=vals[i];vals[i]=vals[j];vals[j]=t}
            floor_idx = int(n * 0.10) + 1
            ceil_idx  = int(n * 0.90); if (ceil_idx < 1) ceil_idx = 1
            printf "%s %s", vals[floor_idx], vals[ceil_idx]
        }
    ')"

    # Steadfastness: % of trials >= 50% of pb
    local consist_recent steadfast_threshold
    consist_recent=$(tail -n20 "$DATA_FILE" | awk -F',' -v pb="$pb" '
        { t++; if (pb > 0 && $3 * 100 / pb >= 50) g++ }
        END { printf "%d", (t > 0 ? int(g * 100 / t) : 0) }
    ')
    steadfast_threshold=$(( pb / 2 ))

    # Zone: % of last 20 trials >= 80% of Apex
    local zone_pct=0 zone_threshold=0
    zone_threshold=$(( pb * 80 / 100 ))
    zone_pct=$(tail -n20 "$DATA_FILE" | awk -F',' -v pb="$pb" '
        { t++; if (pb > 0 && $3 * 100 / pb >= 80) g++ }
        END { printf "%d", (t > 0 ? int(g * 100 / t) : 0) }
    ')

    # Nemesis: most-repeated score strictly below the Apex (ties broken by higher score)
    local nemesis_score=0 nemesis_count=0
    read -r nemesis_score nemesis_count <<< "$(awk -F',' -v pb="$pb" '
        $3 < pb { count[$3]++ }
        END {
            best_c = 0; best_s = 0
            for (s in count) {
                if (count[s] > best_c || (count[s] == best_c && s+0 > best_s+0)) {
                    best_c = count[s]; best_s = s
                }
            }
            printf "%d %d", best_s+0, best_c+0
        }
    ' "$DATA_FILE")"

    # Next title threshold
    local next_title_catches=0 next_title_name="" prev_title_catches=0
    local _thresholds=(5 10 15 20 25 30 40 50 75 100 125 150 175 200 250 300 400 500 750 1000)
    local _names=("Apprentice" "Initiate" "Adept" "Keeper" "Knight" "Harbinger" "Conjuror" "Sage" "Phantom" "Sovereign" "Luminant" "Oracle" "Auric" "Specter" "Empyrean" "Revenant" "Colossus" "Legend" "Paragon" "Immortal")
    for (( _i=0; _i<${#_thresholds[@]}; _i++ )); do
        if (( pb < _thresholds[_i] )); then
            next_title_catches=${_thresholds[_i]}
            next_title_name="${_names[_i]}"
            (( _i > 0 )) && prev_title_catches=${_thresholds[_i-1]}
            break
        fi
    done

    # Recent trend
    local trend_line=""
    if (( total >= 10 )); then
        local prev5_avg last5_avg
        read -r prev5_avg last5_avg <<< "$(tail -n10 "$DATA_FILE" | awk -F',' '
            NR<=5  { s1+=$3; n1++ }
            NR>5   { s2+=$3; n2++ }
            END    { printf "%.1f %.1f", (n1>0?s1/n1:0), (n2>0?s2/n2:0) }
        ')"
        local diff
        diff=$(awk "BEGIN {printf \"%.1f\", $last5_avg - $prev5_avg}")
        local sign
        if awk "BEGIN {exit !($diff > 0)}"; then
            sign="${GREEN}▲ +${diff}${RESET}"
        elif awk "BEGIN {exit !($diff < 0)}"; then
            sign="${RED}▼ ${diff}${RESET}"
        else
            sign="${DIM}= no change${RESET}"
        fi
        trend_line="  ${BOLD}Recent trend  :${RESET}  prev 5 avg ${prev5_avg}  →  last 5 avg ${last5_avg}  ${sign}"
    fi

    # ── Print main stats block ─────────────────────────────────────────────────
    gum_header "$(printf 'IVGVLATOR\n· THE RECKONING ·')"
    echo -e "  ${BOLD}Apex          :${RESET}  ${YELLOW}${BOLD}${pb} catches${RESET}"
    if (( days_since_pb == 0 )); then
        echo -e "  ${BOLD}Apex age      :${RESET}  ${DIM}set today${RESET}"
    else
        echo -e "  ${BOLD}Apex age      :${RESET}  ${days_since_pb} day(s)  ${DIM}(set ${pb_date})${RESET}"
    fi
    local stats_rank
    stats_rank=$(get_rank "$pb")
    echo -e "  ${BOLD}Title         :${RESET}  ${stats_rank}"
    if (( next_title_catches > 0 )); then
        local _needed=$(( next_title_catches - pb ))
        local _range=$(( next_title_catches - prev_title_catches ))
        local _done=$(( pb - prev_title_catches ))
        local _bar_width=20
        local _filled=$(( _done * _bar_width / _range ))
        (( _filled > _bar_width )) && _filled=$_bar_width
        local _bar=""
        for (( _b=0; _b<_bar_width; _b++ )); do
            if (( _b < _filled )); then _bar+="="
            elif (( _b == _filled )); then _bar+=">"
            else _bar+=" "
            fi
        done
        echo -e "  ${BOLD}Next title    :${RESET}  ${next_title_name}  ${DIM}[${_bar}]  ${pb} / ${next_title_catches}${RESET}"
    else
        echo -e "  ${BOLD}Next title    :${RESET}  ${DIM}none — maximum title reached${RESET}"
    fi
    local stats_grade_info stats_grade stats_grade_colour
    stats_grade_info=$(get_grade "$last_catches" "$pb")
    stats_grade="${stats_grade_info%%|*}"
    stats_grade_colour="${stats_grade_info##*|}"
    echo -e "  ${BOLD}Last trial    :${RESET}  ${last_catches} catches  ${DIM}(${last_date} ${last_time})${RESET}"
    echo -e "  ${BOLD}Last grade    :${RESET}  ${stats_grade_colour}${stats_grade}${RESET}"
    echo -e "  ${BOLD}Trials        :${RESET}  ${total}"
    echo -e "  ${BOLD}Average       :${RESET}  ${avg} catches  ${DIM}(median: ${median})${RESET}"
    echo -e "  ${BOLD}Total catches :${RESET}  ${sum}"
    echo ""
    echo -e "  ${BOLD}This month    :${RESET}  ${month_sessions} trial(s), avg ${month_avg}  ${DIM}(best: ${best_this_month})  (all-time avg: ${avg})${RESET}"
    echo -e "  ${BOLD}Best month    :${RESET}  ${best_month}  ${DIM}(avg ${best_month_avg})${RESET}"
    echo -e "  ${BOLD}Trials/week   :${RESET}  ${sessions_per_week} avg  ${DIM}(this week: ${this_week_sessions}, best: ${best_this_week})${RESET}"
    echo ""
    echo -e "  ${BOLD}Floor         :${RESET}  ${floor_val} catches  ${DIM}(10th percentile, last 20 trials)${RESET}"
    echo -e "  ${BOLD}Ceiling       :${RESET}  ${ceiling_val} catches  ${DIM}(90th percentile, last 20 trials)${RESET}"
    echo -e "  ${BOLD}Steadfastness :${RESET}  ${consist_recent}%  ${DIM}(last 20)  ≥ ${steadfast_threshold} catches${RESET}"
    echo -e "  ${BOLD}Zone          :${RESET}  ${zone_pct}%  ${DIM}(last 20)  ≥ ${zone_threshold} catches${RESET}"
    if (( nemesis_count >= 2 )); then
        echo -e "  ${BOLD}Nemesis       :${RESET}  ${RED}${nemesis_score} catches${RESET}  ${DIM}(${nemesis_count} times)${RESET}"
    fi
    [[ -n "$trend_line" ]] && echo -e "$trend_line"

    # ── Auguries ───────────────────────────────────────────────────────────────
    local aug_spree_count aug_dom_active aug_spree_peak aug_echo_peak
    if [[ -s "$STREAK_FILE" ]]; then
        local _sp _sc _da _spk _epk
        IFS=',' read -r _sp _sc _da _spk _epk < "$STREAK_FILE"
        aug_spree_count=${_sc:-0}
        aug_dom_active=${_da:-0}
        aug_spree_peak=${_spk:-0}
        aug_echo_peak=${_epk:-0}
    else
        aug_spree_count=0
        aug_dom_active=0
        aug_spree_peak=0
        aug_echo_peak=0
    fi

    local aug_echo_count
    aug_echo_count=$(echo_count "$pb")
    local display_echo_peak=$(( aug_echo_count > aug_echo_peak ? aug_echo_count : aug_echo_peak ))
    local display_spree_peak=$(( aug_spree_count > aug_spree_peak ? aug_spree_count : aug_spree_peak ))

    echo ""
    echo -e "  ${DIM}──────────────────────────────────────${RESET}"
    echo -e "  ${BOLD}AUGURIES${RESET}"
    echo -e "  ${DIM}──────────────────────────────────────${RESET}"

    # Chain
    if (( cur_streak >= 2 )); then
        echo -e "  ${BOLD}Chain      :${RESET}  ${GREEN}${cur_streak} day(s)${RESET}  ${DIM}(best: ${best_streak})${RESET}"
    else
        echo -e "  ${BOLD}Chain      :${RESET}  ${DIM}inactive  (best: ${best_streak})${RESET}"
    fi

    # Spree
    if (( aug_spree_count >= 3 )); then
        echo -e "  ${BOLD}Spree      :${RESET}  ${CYAN}${aug_spree_count} worthy trial(s)${RESET}  ${DIM}(best: ${display_spree_peak})${RESET}"
    else
        echo -e "  ${BOLD}Spree      :${RESET}  ${DIM}inactive  (best: ${display_spree_peak})${RESET}"
    fi

    # Dominance
    if (( aug_dom_active )); then
        echo -e "  ${BOLD}Dominance  :${RESET}  ${YELLOW}active${RESET}"
    else
        echo -e "  ${BOLD}Dominance  :${RESET}  ${DIM}inactive${RESET}"
    fi

    # Echo
    if (( aug_echo_count >= 3 )); then
        echo -e "  ${BOLD}Echo       :${RESET}  ${MAGENTA}${aug_echo_count} times${RESET}  ${DIM}(best: ${display_echo_peak})${RESET}"
    else
        echo -e "  ${BOLD}Echo       :${RESET}  ${DIM}inactive  (best: ${display_echo_peak})${RESET}"
    fi

    # ── Titles ────────────────────────────────────────────────────────────────
    local t_thresholds=(0 5 10 15 20 25 30 40 50 75 100 125 150 175 200 250 300 400 500 750 1000)
    local t_names=("Neophyte" "Apprentice" "Initiate" "Adept" "Keeper" "Knight" "Harbinger" "Conjuror" "Sage" "Phantom" "Sovereign" "Luminant" "Oracle" "Auric" "Specter" "Empyrean" "Revenant" "Colossus" "Legend" "Paragon" "Immortal")
    local t_colours=("" "" "" "" "${CYAN}" "${CYAN}" "${CYAN}" "${CYAN}" "${GREEN}" "${GREEN}" "${GREEN}" "${YELLOW}" "${YELLOW}" "${YELLOW}" "${YELLOW}" "${MAGENTA}" "${MAGENTA}" "${MAGENTA}" "${RED}" "${RED}" "${YELLOW}${BOLD}")

    local current_idx=0
    for (( i=0; i<${#t_thresholds[@]}; i++ )); do
        (( pb >= t_thresholds[i] )) && current_idx=$i
    done

    echo ""
    echo -e "  ${DIM}──────────────────────────────────────${RESET}"
    echo -e "  ${BOLD}TITLES${RESET}"
    echo -e "  ${DIM}──────────────────────────────────────${RESET}"

    local win_above=3 win_below=3
    local window_start=$(( current_idx - win_above ))
    (( window_start < 0 )) && window_start=0
    local window_end=$(( current_idx + win_below ))
    (( window_end >= ${#t_thresholds[@]} )) && window_end=$(( ${#t_thresholds[@]} - 1 ))

    if (( window_start > 0 )); then
        echo -e "  ${DIM}·  … and ${window_start} more${RESET}"
    fi

    local i
    for (( i=window_start; i<=window_end; i++ )); do
        if (( i == current_idx )); then
            printf "  ${t_colours[i]}✔  %-15s  (%d+)${RESET}  ${DIM}← current${RESET}\n" "${t_names[i]}" "${t_thresholds[i]}"
        elif (( i < current_idx )); then
            printf "  ✔  %-15s  (%d+)\n" "${t_names[i]}" "${t_thresholds[i]}"
        else
            printf "  ${DIM}·  %-15s  (%d+)${RESET}\n" "${t_names[i]}" "${t_thresholds[i]}"
        fi
    done

    local remaining=$(( ${#t_thresholds[@]} - 1 - window_end ))
    if (( remaining > 0 )); then
        echo -e "  ${DIM}·  … and ${remaining} more${RESET}"
    fi

    # ── Apex Record ────────────────────────────────────────────────────────────
    echo -e "\n  ${BOLD}Apex Record${RESET}  ${DIM}(last 10)${RESET}"
    echo -e "  ${DIM}$(printf '─%.0s' {1..38})${RESET}"
    show_apex "$pb" no_header

    # ── Trial Ledger ───────────────────────────────────────────────────────────
    echo ""
    echo -e "  ${DIM}──────────────────────────────────────${RESET}"
    echo -e "  ${BOLD}TRIAL LEDGER${RESET}"
    echo -e "  ${DIM}──────────────────────────────────────${RESET}"

    # Build bands up to highest score ever recorded (rounded up to next band)
    local highest
    highest=$(awk -F',' 'BEGIN{m=0} $3>m{m=$3} END{print m}' "$DATA_FILE")
    local max_band=$(( ( (highest / 5) + 1 ) * 5 ))

    # Find widest label for alignment (zero-padded starts below 10)
    local widest=0
    for (( band=0; band<max_band; band+=5 )); do
        local band_end=$(( band + 4 ))
        local label_start
        printf -v label_start "%02d" "$band"
        local label_end
        printf -v label_end "%02d" "$band_end"
        local lw=${#label_start}
        local ew=${#label_end}
        local total_w=$(( lw + 1 + ew ))
        (( total_w > widest )) && widest=$total_w
    done

    # Find max count for bar scaling (only non-empty bands)
    local band_max=0
    for (( band=0; band<max_band; band+=5 )); do
        local band_end=$(( band + 4 ))
        local count
        count=$(awk -F',' -v lo="$band" -v hi="$band_end" '$3>=lo && $3<=hi' "$DATA_FILE" | wc -l | tr -d ' ')
        (( count > band_max )) && band_max=$count
    done

    for (( band=0; band<max_band; band+=5 )); do
        local band_end=$(( band + 4 ))
        local count
        count=$(awk -F',' -v lo="$band" -v hi="$band_end" '$3>=lo && $3<=hi' "$DATA_FILE" | wc -l | tr -d ' ')
        # Skip empty bands
        (( count == 0 )) && continue
        local label_start label_end
        printf -v label_start "%02d" "$band"
        printf -v label_end "%02d" "$band_end"
        local label="${label_start}–${label_end}"
        local bar_len=0
        (( band_max > 0 )) && bar_len=$(( count * 28 / band_max ))
        (( count > 0 && bar_len < 1 )) && bar_len=1
        # Print label
        printf "  ${DIM}%*s${RESET}  " "$widest" "$label"
        # Print bar character by character to avoid UTF-8 width miscounting
        local bar_color
        if (( band >= pb )); then bar_color="$YELLOW"; else bar_color="$CYAN"; fi
        for (( b=0; b<28; b++ )); do
            if (( b < bar_len )); then
                printf "%b" "${bar_color}█${RESET}"
            else
                printf " "
            fi
        done
        # Print count in fixed right column
        printf "  ${DIM}%4d${RESET}\n" "$count"
    done

    # ── Last 20 trials — vertical average line ────────────────────────────────
    echo ""
    echo -e "  ${DIM}──────────────────────────────────────${RESET}"
    echo -e "  ${BOLD}LAST 20 TRIALS${RESET}  ${DIM}(${YELLOW}│${DIM} = all-time avg ${avg})${RESET}"
    echo -e "  ${DIM}──────────────────────────────────────${RESET}"

    local chart_width=24
    local max_val
    max_val=$(tail -n20 "$DATA_FILE" | awk -F',' 'BEGIN{m=0} $3>m{m=$3} END{print m}')
    (( max_val < 1 )) && max_val=1

    local avg_int
    avg_int=$(awk "BEGIN {printf \"%d\", int($avg + 0.5)}")
    # Column position of the average line within chart_width
    local avg_pos=$(( avg_int * chart_width / max_val ))
    (( avg_pos >= chart_width )) && avg_pos=$(( chart_width - 1 ))

    while IFS=',' read -r date _ val; do
        local bar_len=$(( val * chart_width / max_val ))
        (( val > 0 && bar_len < 1 )) && bar_len=1

        # Build bar with │ at avg_pos; use ┼ where bar and avg line overlap
        local line=""
        for (( col=0; col<chart_width; col++ )); do
            if (( col == avg_pos )); then
                if (( col < bar_len )); then
                    line+="┼"
                else
                    line+="│"
                fi
            elif (( col < bar_len )); then
                line+="█"
            else
                line+=" "
            fi
        done

        printf "  ${DIM}%s${RESET}  ${CYAN}%s${RESET}  ${DIM}%2d${RESET}\n" "$date" "$line" "$val"
    done < <(tail -n20 "$DATA_FILE")
    echo ""
}

