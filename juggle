    echo -e "  ${BOLD}Best          :${RESET}  ${BOLD}${day_best} catches${RESET}  ${grade_colour}${grade}${RESET}"
    echo -e "  ${BOLD}Avg           :${RESET}  ${day_avg}  ${DIM}(all-time avg: ${alltime_avg})${RESET}"
    if (( is_current )); then
        local _above_count _gloss
        _above_count=$(awk -F',' -v d="$target_date" -v avg="$alltime_avg" '
            $1 == d && $3+0 > avg+0 { n++ }
            END { print n+0 }
        ' "$DATA_FILE")
        if (( day_count == 1 )); then
            if (( _above_count == 1 )); then
                _gloss="A trial above the long line."
            else
                _gloss="A trial below the long line."
            fi
        elif (( _above_count == day_count )); then
            _gloss="Every trial today cleared the long line."
        elif (( _above_count * 5 >= day_count * 3 )); then
            _gloss="Most trials today cleared the long line."
        elif (( _above_count * 5 <= day_count * 2 )); then
            if (( _above_count == 0 )); then
                _gloss="No trial today reached the long line."
            else
                _gloss="Few trials today reached the long line."
            fi
        else
            _gloss="The trials were divided."
        fi
        echo ""
        echo -e "  ${DIM}${_gloss}${RESET}"
    fi
    echo ""
}

# ── Week recap ─────────────────────────────────────────────────────────────────

show_week() {
    local total
    total=$(total_sessions)

    if (( total == 0 )); then
        echo -e "\n  No trials logged yet.\n"
        return
    fi

    local ref_date is_current=0
    if [[ -n "$1" ]]; then
        if [[ "$1" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then
            ref_date="$1"
        else
            echo -e "\n  ${RED}Invalid date format:${RESET} '$1'  ${DIM}(use YYYY-MM-DD)${RESET}\n"
            return 1
        fi
    else
        ref_date=$(date +%Y-%m-%d)
        is_current=1
    fi

    local dow week_start week_end
    dow=$(date -d "$ref_date" +%u)
    week_start=$(date -d "$ref_date -$(( dow - 1 )) days" +%Y-%m-%d)
    week_end=$(date -d "$week_start +6 days" +%Y-%m-%d)

    local w_count w_best w_sum
    read -r w_count w_best w_sum <<< "$(awk -F',' -v s="$week_start" -v e="$week_end" '
        $1 >= s && $1 <= e { n++; s2+=$3; if ($3 > best) best=$3 }
        END { printf "%d %d %d", n+0, best+0, s2+0 }
    ' "$DATA_FILE")"

    if (( w_count == 0 )); then
        echo -e "\n  No trials in week of ${week_start}.\n"
        return
    fi

    local w_avg
    w_avg=$(awk "BEGIN {printf \"%.1f\", $w_sum / $w_count}")

    local alltime_avg
    alltime_avg=$(awk -F',' '{s+=$3; n++} END {printf "%.1f", (n>0?s/n:0)}' "$DATA_FILE")

    local active_days
    active_days=$(awk -F',' -v s="$week_start" -v e="$week_end" '
        $1 >= s && $1 <= e {days[$1]=1}
        END {print length(days)+0}
    ' "$DATA_FILE")

    local prev_week_start prev_week_end
    prev_week_start=$(date -d "$week_start -7 days" +%Y-%m-%d)
    prev_week_end=$(date -d "$week_start -1 day" +%Y-%m-%d)
    local prev_count prev_avg
    read -r prev_count prev_avg <<< "$(awk -F',' -v s="$prev_week_start" -v e="$prev_week_end" '
        $1 >= s && $1 <= e {sum+=$3; n++}
        END { printf "%d %.1f", n+0, (n>0?sum/n:0) }
    ' "$DATA_FILE")"

    local week_sign=""
    if (( prev_count > 0 )); then
        local diff
        diff=$(awk "BEGIN {printf \"%.1f\", $w_avg - $prev_avg}")
        if awk "BEGIN {exit !($diff > 0)}"; then
            week_sign="  ${GREEN}▲ +${diff} vs prev week${RESET}"
        elif awk "BEGIN {exit !($diff < 0)}"; then
            week_sign="  ${RED}▼ ${diff} vs prev week${RESET}"
        else
            week_sign="  ${DIM}= no change vs prev week${RESET}"
        fi
    fi

    local pb
    pb=$(personal_best)
    local grade_info grade grade_colour
    grade_info=$(get_grade "$w_best" "$pb")
    grade="${grade_info%%|*}"
    grade_colour="${grade_info##*|}"

    local week_label
    week_label="$(date -d "$week_start" "+%b %-d") – $(date -d "$week_end" "+%b %-d, %Y")"

    echo ""
    echo -e "  ${DIM}──────────────────────────────────────${RESET}"
    echo -e "  ${BOLD}WEEK${RESET}  ${DIM}${week_label}${RESET}"
    echo -e "  ${DIM}──────────────────────────────────────${RESET}"
    echo -e "  ${BOLD}Trials        :${RESET}  ${w_count}"
    echo -e "  ${BOLD}Active days   :${RESET}  ${active_days} of 7"
    echo -e "  ${BOLD}Best          :${RESET}  ${BOLD}${w_best} catches${RESET}  ${grade_colour}${grade}${RESET}"
    echo -e "  ${BOLD}Avg           :${RESET}  ${w_avg}  ${DIM}(all-time: ${alltime_avg})${RESET}${week_sign}"
    if (( is_current )); then
        local _week_rank _week_total _gloss
        read -r _week_rank _week_total <<< "$(awk -F',' -v ws="$week_start" '
            function wstart(d,    y,m,dd,t,dow) {
                y=substr(d,1,4)+0; m=substr(d,6,2)+0; dd=substr(d,9,2)+0
                t=mktime(y " " m " " dd " 12 0 0")
                dow=strftime("%u",t)+0
                return strftime("%Y-%m-%d", t-(dow-1)*86400)
            }
            { key=wstart($1); sum[key]+=$3; cnt[key]++ }
            END {
                cur=(cnt[ws]>0 ? sum[ws]/cnt[ws] : 0)
                n=0; rank=1
                for (k in sum) {
                    n++
                    if (k != ws && sum[k]/cnt[k] > cur) rank++
                }
                print rank, n
            }
        ' "$DATA_FILE")"
        if (( _week_total == 1 )); then
            _gloss="The first week on record."
        elif (( _week_rank == 1 )); then
            _gloss="The strongest week on record."
        elif (( _week_rank == _week_total )); then
            _gloss="The weakest week on record."
        elif (( _week_rank * 4 <= _week_total )); then
            _gloss="Among the stronger weeks on record."
        elif (( _week_rank * 4 >= _week_total * 3 )); then
            _gloss="Among the weaker weeks on record."
        else
            _gloss="A middle-of-the-record week."
        fi
        echo ""
        echo -e "  ${DIM}${_gloss}${RESET}"
    fi
    echo ""
}

