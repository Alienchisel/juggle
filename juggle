    read -r best_month_key best_month_avg <<< "$(awk -F',' -v y="$target_year" '
        substr($1,1,4) == y {
            key = substr($1,1,7)
            sum[key] += $3
            count[key]++
        }
        END {
            best_avg = 0; best_key = ""
            for (k in sum) {
                a = sum[k] / count[k]
                if (a > best_avg) { best_avg = a; best_key = k }
            }
            printf "%s %.1f", best_key, best_avg
        }
    ' "$DATA_FILE")"
    local best_month_label
    best_month_label=$(date -d "${best_month_key}-01" "+%B")

    local pb
    pb=$(personal_best)
    local grade_info grade grade_colour
    grade_info=$(get_grade "$y_best" "$pb")
    grade="${grade_info%%|*}"
    grade_colour="${grade_info##*|}"

    echo ""
    echo -e "  ${DIM}──────────────────────────────────────${RESET}"
    echo -e "  ${BOLD}YEAR${RESET}  ${DIM}${target_year}${RESET}"
    echo -e "  ${DIM}──────────────────────────────────────${RESET}"
    echo -e "  ${BOLD}Trials        :${RESET}  ${y_count}"
    echo -e "  ${BOLD}Active days   :${RESET}  ${active_days}"
    echo -e "  ${BOLD}Best          :${RESET}  ${BOLD}${y_best} catches${RESET}  ${grade_colour}${grade}${RESET}"
    echo -e "  ${BOLD}Avg           :${RESET}  ${y_avg}  ${DIM}(all-time: ${alltime_avg})${RESET}${year_sign}"
    echo -e "  ${BOLD}Best month    :${RESET}  ${best_month_label}  ${DIM}(avg ${best_month_avg})${RESET}"
    if (( is_current )); then
        local _year_count _gloss
        _year_count=$(awk -F',' '{y[substr($1,1,4)]=1} END{print length(y)}' "$DATA_FILE")
        if (( _year_count == 1 )); then
            _gloss="The first year on record."
        elif awk "BEGIN {exit !($y_avg > $alltime_avg)}"; then
            _gloss="A year above the long average. ${best_month_label} was its strongest month."
        elif awk "BEGIN {exit !($y_avg < $alltime_avg)}"; then
            _gloss="The year has fallen below the long average. ${best_month_label} carried the most."
        else
            _gloss="The year holds at the long average."
        fi
        echo ""
        echo -e "  ${DIM}${_gloss}${RESET}"
    fi
    echo ""
}

# ── Last entry ─────────────────────────────────────────────────────────────────

show_last() {
    local n=${1:-1}
    local total
    total=$(total_sessions)
    if (( total == 0 )); then
        echo -e "\n  No trials logged yet.\n"
        return
    fi
    (( n > total )) && n=$total
    local pb
    pb=$(personal_best)
    echo ""
    local _title
    (( n == 1 )) && _title="RECENT TRIAL" || _title="RECENT TRIALS"
    echo -e "  ${BOLD}${_title}${RESET}"
    echo -e "  ${DIM}──────────────────────────────────────${RESET}"
    echo ""
    local i=1
    while IFS=',' read -r row_date row_time row_catches; do
        local grade_info grade colour
        grade_info=$(get_grade "$row_catches" "$pb")
        grade="${grade_info%%|*}"
        colour="${grade_info##*|}"
        printf "  ${BOLD}%3d.${RESET}  ${BOLD}%3d catches${RESET}   ${DIM}%s  %s${RESET}   ${colour}%-3s${RESET}\n" \
            "$i" "$row_catches" "$row_date" "$row_time" "$grade"
        (( i++ ))
    done < <(tail -n"$n" "$DATA_FILE" | tac)
    echo ""
}

# ── Undo ───────────────────────────────────────────────────────────────────────

undo_last() {
    local total
    total=$(total_sessions)
    if (( total == 0 )); then
        echo -e "\n  ${RED}Nothing to undo — no trials logged yet.${RESET}\n"
        return
    fi
    local last_date last_time last_catches
    IFS=',' read -r last_date last_time last_catches <<< "$(tail -n1 "$DATA_FILE")"
    echo ""
    echo -e "  ${BOLD}Last entry:${RESET}  ${BOLD}${last_catches} catches${RESET}  ${DIM}(${last_date} ${last_time})${RESET}"
    if gum_confirm "Remove this entry?"; then
        local tmp
        tmp=$(mktemp)
        head -n -1 "$DATA_FILE" > "$tmp" && mv "$tmp" "$DATA_FILE"
        if [[ -s "$PB_FILE" ]]; then
            local last_pb
            last_pb=$(tail -n1 "$PB_FILE" | cut -d',' -f3)
            if (( last_catches == last_pb )); then
                tmp=$(mktemp)
                head -n -1 "$PB_FILE" > "$tmp" && mv "$tmp" "$PB_FILE"
            fi
        fi
        # Recompute augury state from post-undo data
        local new_pb
        new_pb=$(personal_best)
        local new_spree=0
        if [[ -s "$DATA_FILE" ]] && (( new_pb > 0 )); then
            while IFS=',' read -r _ _ c; do
                if (( c * 100 / new_pb >= 50 )); then
                    (( new_spree++ ))
                else
                    break
                fi
            done < <(tac "$DATA_FILE")
        fi
        local new_dom=0
        local new_total
        new_total=$(total_sessions)
        if (( new_pb > 0 && new_total >= 10 )); then
            local dom_count
            dom_count=$(tail -n10 "$DATA_FILE" | awk -F',' -v pb="$new_pb" '
                { if ($3 * 100 / pb >= 80) count++ }
                END { print count+0 }
            ')
            (( dom_count >= 5 )) && new_dom=1
        fi
        local new_cur_streak new_streak_peak=0
        read -r new_cur_streak _ <<< "$(calc_streaks)"
        local st
        for st in 3 7 14 30 60 90 180 365 730; do
            (( new_cur_streak >= st )) && new_streak_peak=$st
        done
        echo "${new_streak_peak},${new_spree},${new_dom}" > "$STREAK_FILE"

        echo -e "  ${GREEN}Entry removed.${RESET}"
    else
        echo -e "  ${DIM}Cancelled — nothing changed.${RESET}"
    fi
    echo ""
}


